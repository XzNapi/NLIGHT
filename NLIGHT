local function isOutOfBounds(x, y)
    local minBound = workspace:GetAttribute("WorldMin")
    local maxBound = workspace:GetAttribute("WorldMax")
    if minBound and maxBound then
        if x < minBound.X or x > maxBound.X or y < minBound.Y or y > maxBound.Y then return true end
    end
    if WorldTiles and type(WorldTiles) == "table" then
        if rawget(WorldTiles, x) == nil and rawget(WorldTiles, tostring(x)) == nil then return true end
    end
    return false
end

-- SMART BLACKLIST: Deteksi Jika Item Nyangkut
local function isItemTrapped(x, y)
    if not WorldManager or not WorldManager.GetTile then return false end
    
    -- Jika posisi item itu sendiri tertumpuk block solid, berarti tidak bisa diambil
    if WorldManager.GetTile(x, y, 1) then return true end
    
    -- Jika diapit 4 block solid (Atas, Bawah, Kiri, Kanan)
    local up = WorldManager.GetTile(x, y + 1, 1)
    local down = WorldManager.GetTile(x, y - 1, 1)
    local right = WorldManager.GetTile(x + 1, y, 1)
    local left = WorldManager.GetTile(x - 1, y, 1)
    
    if up and down and right and left then return true end
    
    return false
end

local function isLineOfSightClear(x0, y0, x1, y1)
    local dx = math.abs(x1 - x0)
    local dy = math.abs(y1 - y0)
    local sx = x0 < x1 and 1 or -1
    local sy = y0 < y1 and 1 or -1
    local err = dx - dy

    while true do
        if isOutOfBounds(x0, y0) then return false end 
        if x0 == x1 and y0 == y1 then break end
        local e2 = 2 * err
        if e2 > -dy then err = err - dy; x0 = x0 + sx end
        if e2 < dx then err = err + dx; y0 = y0 + sy end
        if WorldManager and WorldManager.GetTile and (x0 ~= x1 or y0 ~= y1) then
            if WorldManager.GetTile(x0, y0, 1) then return false end
        end
    end
    return true
end

-- UNLIMITED OPTIMIZED A* ALGORITHM
local function getPath(startX, startY, endX, endY)
    local open = {}
    local closed = {}
    local nodeGrid = {} 
    
    local startNode = {x = startX, y = startY, g = 0, f = 0, parent = nil}
    table.insert(open, startNode)
    nodeGrid[startX .. "," .. startY] = startNode
    
    local iter = 0
    -- Movement Dirs & Cost
    local dirs = {
        {dx=1, dy=0, cost=10}, {dx=-1, dy=0, cost=10}, {dx=0, dy=1, cost=10}, {dx=0, dy=-1, cost=10},
        {dx=1, dy=1, cost=14}, {dx=1, dy=-1, cost=14}, {dx=-1, dy=1, cost=14}, {dx=-1, dy=-1, cost=14}
    }
    
    while #open > 0 do
        iter = iter + 1
        if iter % 1000 == 0 then task.wait() end -- Mencegah crash jika map sangat luas
        
        -- Cari node dengan f terendah
        local currIdx = 1
        local currNode = open[1]
        for i = 2, #open do
            if open[i].f < currNode.f then
                currNode = open[i]
                currIdx = i
            end
        end
        table.remove(open, currIdx)
        
        local key = currNode.x .. "," .. currNode.y
        closed[key] = true
        
        if currNode.x == endX and currNode.y == endY then
            local path = {}
            local temp = currNode
            while temp do table.insert(path, 1, Vector2.new(temp.x, temp.y)); temp = temp.parent end
            return path
        end
        
        for _, d in ipairs(dirs) do
            local nx = currNode.x + d.dx
            local ny = currNode.y + d.dy
            local nKey = nx .. "," .. ny
            
            if not closed[nKey] then
                local isSolid = false
                if isOutOfBounds(nx, ny) then
                    isSolid = true
                elseif (nx ~= endX or ny ~= endY) and WorldManager and WorldManager.GetTile then
                    if WorldManager.GetTile(nx, ny, 1) then isSolid = true end
                    
                    -- ANTI TABRAK: Cegah memotong sudut menyilang (Corner Cutting) jika ada blok di sampingnya
                    if not isSolid and d.cost == 14 then
                        if WorldManager.GetTile(currNode.x + d.dx, currNode.y, 1) or WorldManager.GetTile(currNode.x, currNode.y + d.dy, 1) then 
                            isSolid = true 
                        end
                    end
                end
                
                if not isSolid then
                    local g = currNode.g + d.cost
                    local h = 10 * (math.abs(nx - endX) + math.abs(ny - endY)) + (14 - 20) * math.min(math.abs(nx - endX), math.abs(ny - endY))
                    local f = g + h
                    
                    local existingNode = nodeGrid[nKey]
                    if not existingNode or g < existingNode.g then
                        if not existingNode then
                            local newNode = {x=nx, y=ny, g=g, f=f, parent=currNode}
                            table.insert(open, newNode)
                            nodeGrid[nKey] = newNode
                        else
                            existingNode.g = g
                            existingNode.f = f
                            existingNode.parent = currNode
                        end
                    end
                end
            end
        end
    end
    return nil -- Return nil jika sama sekali tidak ada jalan
end

local function aiMoveTo(endX, endY, moveSpeed, toggleKey)
    local startX = math.floor(MovementState.Position.X / TILE_SIZE + 0.5)
    local startY = math.floor(MovementState.Position.Y / TILE_SIZE + 0.5)
    local path = nil
    
    if isLineOfSightClear(startX, startY, endX, endY) then
        path = { Vector2.new(startX, startY), Vector2.new(endX, endY) }
    else
        path = getPath(startX, startY, endX, endY)
    end
    
    if path then
        for i = 2, #path do
            if not toggles[toggleKey] then break end
            local nodePos = Vector3.new(path[i].X, path[i].Y, 0) * TILE_SIZE
            while toggles[toggleKey] do
                local currentPos = MovementState.Position
                local distToNode = (nodePos - currentPos).Magnitude
                if distToNode < 0.5 then
                    MovementState.Position = nodePos
                    break
                end
                local dt = task.wait()
                local dir = (nodePos - currentPos).Unit
                local step = dir * moveSpeed * dt
                if step.Magnitude > distToNode then
                    MovementState.Position = nodePos
                    break
                else
                    MovementState.Position = currentPos + step
                    MovementState.OldPosition = MovementState.Position
                    MovementState.VelocityX, MovementState.VelocityY = 0, 0
                end
            end
        end
        return true
    end
    return false
end

