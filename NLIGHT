-- AUTO BREAKER (ZIG-ZAG)
-- ==========================================
task.spawn(function()
    while task.wait() do
        pcall(function()
            if toggles.autoBreaker and MovementState and PlayerFistRemote then
                local pPos = MovementState.Position
                local targetStr = string.lower(inputInstances["breakerTargetBox"] and inputInstances["breakerTargetBox"].Text or "")
                if targetStr == "" then return end

                local validSpots = {}
                local minBound = workspace:GetAttribute("WorldMin")
                local maxBound = workspace:GetAttribute("WorldMax")

                if minBound and maxBound and WorldManager and WorldManager.GetTile then
                    for x = minBound.X, maxBound.X do
                        for y = minBound.Y, maxBound.Y do
                            local tileCurrent = WorldManager.GetTile(x, y, 1)
                            if tileCurrent and not blacklistedSpots[x..","..y] then
                                local isMatch = false
                                if ItemsManager and ItemsManager.ItemsData and ItemsManager.ItemsData[tileCurrent] then
                                    if string.find(string.lower(tostring(ItemsManager.ItemsData[tileCurrent].Name)), targetStr) then isMatch = true end
                                elseif string.find(string.lower(tostring(tileCurrent)), targetStr) then isMatch = true end

                                if isMatch then
                                    table.insert(validSpots, {x = x, y = y})
                                end
                            end
                        end
                    end
                end

                if #validSpots > 0 then
                    local rows = {}
                    local sortedY = {}
                    for _, spot in ipairs(validSpots) do
                        if not rows[spot.y] then
                            rows[spot.y] = {}
                            table.insert(sortedY, spot.y)
                        end
                        table.insert(rows[spot.y], spot)
                    end

                    table.sort(sortedY, function(a, b) return a < b end)

                    local targetY = sortedY[1]
                    local minYDist = math.huge
                    local yIndex = 1
                    for i, y in ipairs(sortedY) do
                        local yDist = math.abs(pPos.Y - (y * TILE_SIZE))
                        if yDist < minYDist then
                            minYDist = yDist
                            targetY = y
                            yIndex = i
                        end
                    end

                    local rowSpots = rows[targetY]
                    
                    if yIndex % 2 == 0 then
                        table.sort(rowSpots, function(a, b) return a.x < b.x end) -- Kiri ke Kanan (Zig-zag balik)
                    else
                        table.sort(rowSpots, function(a, b) return a.x > b.x end) -- Kanan ke Kiri (Awal)
                    end

                    local targetSpot = rowSpots[1]
                    local moveSpeed = tonumber(inputInstances["breakerSpeedBox"] and inputInstances["breakerSpeedBox"].Text or "45") or 45
                    
                    if aiMoveTo(targetSpot.x, targetSpot.y, moveSpeed, "autoBreaker") then
                        local hitsToSend = toggles.oneHitBreak and (tonumber(inputInstances["hitMultiplierBox"] and inputInstances["hitMultiplierBox"].Text or "25") or 25) or 1
                        for i = 1, hitsToSend do PlayerFistRemote:FireServer(Vector2.new(targetSpot.x, targetSpot.y)) end
                        if not toggles.antiLag and PCM and PCM.SpawnHitParticle then PCM.SpawnHitParticle(Vector3.new(targetSpot.x * TILE_SIZE, targetSpot.y * TILE_SIZE, 0)) end
                        task.wait(0.1)
                    else
                        blacklistedSpots[targetSpot.x..","..targetSpot.y] = true
                    end
                end
            end
        end)
    end
end)

-- ==========================================
-- GENIUS AUTO-LOOT (UNLIMITED & SMART AVOIDANCE)
-- ==========================================
task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if toggles.autoLoot and MovementState then
                local pPos = MovementState.Position
                local dropsFolder = workspace:FindFirstChild("Drops") or workspace:FindFirstChild("DroppedItems") or workspace:FindFirstChild("Items")
                local itemsToLoot = {}
                
                if dropsFolder then
                    for _, v in ipairs(dropsFolder:GetChildren()) do
                        if (v:IsA("BasePart") or v:IsA("Model")) and not blacklistedItems[v] then 
                            table.insert(itemsToLoot, v) 
                        end
                    end
                else
                    for _, obj in ipairs(workspace:GetChildren()) do
                        if obj:IsA("BasePart") and not obj:IsDescendantOf(LocalPlayer.Character) and not Players:GetPlayerFromCharacter(obj.Parent) and obj.Size.Y < 3 and not blacklistedItems[obj] then
                            table.insert(itemsToLoot, obj)
                        end
                    end
                end
                
                if #itemsToLoot > 0 then
                    -- SORTIR ITEM: Dari Jarak Terdekat ke Terjauh (Penting!)
                    table.sort(itemsToLoot, function(a, b)
                        local posA = a:IsA("BasePart") and a.Position or (a:IsA("Model") and a.PrimaryPart and a.PrimaryPart.Position) or Vector3.new(9999,9999,9999)
                        local posB = b:IsA("BasePart") and b.Position or (b:IsA("Model") and b.PrimaryPart and b.PrimaryPart.Position) or Vector3.new(9999,9999,9999)
                        return (pPos - posA).Magnitude < (pPos - posB).Magnitude
                    end)
                    
                    local moveSpeed = tonumber(lootSpeedBox.Text) or 45
                    
                    for _, item in ipairs(itemsToLoot) do
                        if not toggles.autoLoot then break end
                        local part = item:IsA("BasePart") and item or (item:IsA("Model") and item.PrimaryPart)
                        
                        if part and part.Parent then
                            local targetPos = part.Position
                            local endX = math.floor(targetPos.X / TILE_SIZE + 0.5)
                            local endY = math.floor(targetPos.Y / TILE_SIZE + 0.5)
                            
                            -- Pengecekan Cerdas: Jangan ambil jika item diluar batas, atau "TERPERANGKAP" di dalam block
                            if isOutOfBounds(endX, endY) or isItemTrapped(endX, endY) then
                                blacklistedItems[item] = true
                            else
                                if not aiMoveTo(endX, endY, moveSpeed, "autoLoot") then
                                    -- Jika tidak ada jalan yang ditemukan oleh A*, blacklist itemnya agar tidak memaksa
                                    blacklistedItems[item] = true
                                end
                            end
                        end
                    end
                end
            end
        end)
    end
end)

