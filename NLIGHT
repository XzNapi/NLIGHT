                local plantStr = string.lower(inputInstances["planterItemBox"] and inputInstances["planterItemBox"].Text or "")
                local baseStr = string.lower(inputInstances["planterBaseBox"] and inputInstances["planterBaseBox"].Text or "dirt")
                if plantStr == "" or baseStr == "" then return end

                local slotIndexToSend = tonumber(plantStr)
                if not slotIndexToSend and InventoryModule and InventoryModule.Stacks then
                    local exactMatch, partialMatch = nil, nil
                    for i = 1, (InventoryModule.MaxSlots or 100) do
                        local stackInfo = InventoryModule.Stacks[i]
                        if stackInfo and stackInfo.Id and stackInfo.Amount and stackInfo.Amount > 0 then
                            local currentID = string.lower(tostring(stackInfo.Id))
                            if currentID == plantStr then exactMatch = i break
                            elseif string.find(currentID, plantStr) and not partialMatch then partialMatch = i end
                        end
                    end
                    slotIndexToSend = exactMatch or partialMatch
                end

                if not slotIndexToSend then
                    print("[NLight] Auto Planter: Item habis atau tidak ditemukan!")
                    toggles.autoPlanter = false
                    updatePlanterToggle() 
                    return
                end

                local validSpots = {}
                local minBound = workspace:GetAttribute("WorldMin")
                local maxBound = workspace:GetAttribute("WorldMax")

                if minBound and maxBound and WorldManager and WorldManager.GetTile then
                    for x = minBound.X, maxBound.X do
                        for y = minBound.Y, maxBound.Y do
                            local tileBelow = WorldManager.GetTile(x, y - 1, 1)
                            local tileCurrent = WorldManager.GetTile(x, y, 1)

                            local isMatchBase = false
                            if tileBelow then
                                if ItemsManager and ItemsManager.ItemsData and ItemsManager.ItemsData[tileBelow] then
                                    if string.find(string.lower(tostring(ItemsManager.ItemsData[tileBelow].Name)), baseStr) then isMatchBase = true end
                                elseif string.find(string.lower(tostring(tileBelow)), baseStr) then isMatchBase = true end
                            end

                            if isMatchBase and not tileCurrent and not blacklistedSpots[x..","..y] then
                                table.insert(validSpots, {x = x, y = y})
                            end
                        end
                    end
                end

                if #validSpots > 0 then
                    local rows = {}
                    for _, spot in ipairs(validSpots) do
                        rows[spot.y] = rows[spot.y] or {}
                        table.insert(rows[spot.y], spot)
                    end

                    local targetY = validSpots[1].y
                    local minYDist = math.huge
                    for y, _ in pairs(rows) do
                        local yDist = math.abs(pPos.Y - (y * TILE_SIZE))
                        if yDist < minYDist then
                            minYDist = yDist
                            targetY = y
                        end
                    end

                    local rowSpots = rows[targetY]
                    table.sort(rowSpots, function(a, b) return a.x > b.x end) -- Kanan ke Kiri (X terbesar ke terkecil)

                    local targetSpot = rowSpots[1]
                    local moveSpeed = tonumber(inputInstances["planterSpeedBox"] and inputInstances["planterSpeedBox"].Text or "45") or 45
                    
                    if aiMoveTo(targetSpot.x, targetSpot.y, moveSpeed, "autoPlanter") then
                        PlayerPlaceRemote:FireServer(Vector2.new(targetSpot.x, targetSpot.y), slotIndexToSend)
                        task.wait(0.1)
                    else
                        blacklistedSpots[targetSpot.x..","..targetSpot.y] = true
                    end
                end
            end
        end)
    end
end)

