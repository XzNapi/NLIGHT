UIS.InputBegan:Connect(function(input, gpe)
    if input.KeyCode == Enum.KeyCode.Space then isHoldingSpace = true end
    if gpe then return end 
    local isTouchOrClick = (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton3)
    
    if isTouchOrClick then
        pcall(function()
            if toggles.devTeleport and MovementState then
                local targetGrid = getGridFromScreen(input.Position.X, input.Position.Y)
                if targetGrid then
                    local newPos = Vector3.new(targetGrid.X, targetGrid.Y, 0) * TILE_SIZE
                    MovementState.Position = newPos
                    MovementState.OldPosition = newPos
                    MovementState.VelocityX, MovementState.VelocityY = 0, 0
                end
                return 
            end
        end)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Space then isHoldingSpace = false end
end)

RS.RenderStepped:Connect(function()
    pcall(function()
        if toggles.godMode and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.Health = LocalPlayer.Character.Humanoid.MaxHealth end
        if MovementState then
            if toggles.speed and MovementState.MoveX ~= 0 then MovementState.VelocityX = MovementState.MoveX * (tonumber(speedBox.Text) or 2.0) end
            if toggles.infJump then MovementState.RemainingJumps = 999; MovementState.MaxJump = 999 end
            if toggles.fly then 
                MovementState.VelocityY = 0
                if isHoldingSpace then 
                    MovementState.Position = MovementState.Position + Vector3.new(0, 0.4, 0) 
                end 
            end
        end
    end)
end)

